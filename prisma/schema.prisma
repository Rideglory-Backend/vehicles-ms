// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id             String    @id @default(uuid())
  ownerId        String
  name           String
  brand          String
  model          String
  year           Int
  currentMileage Float
  licensePlate   String?
  vin            String?
  purchaseDate   DateTime?
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt()
  isArchived     Boolean   @default(false)
  /// Enforced in DB: partial unique index on (ownerId) WHERE isMainVehicle = true
  /// (see migration 20260508163433; partial unique index is SQL-only)
  isMainVehicle  Boolean   @default(false)
  engine         String?
  horsepower     String?
  torque         String?
  weight         String?
}

model Soat {
  id           String   @id @default(uuid())
  vehicleId    String   @unique
  policyNumber String
  startDate    DateTime
  expiryDate   DateTime
  insurer      String
  documentUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tecnomecanica {
  id                String    @id @default(uuid())
  vehicleId         String    @unique
  certificateNumber String?
  cdaName           String
  startDate         DateTime
  expiryDate        DateTime
  documentUrl       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
